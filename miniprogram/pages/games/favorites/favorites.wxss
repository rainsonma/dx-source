.page-container {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40px;
}
.center-loader { display: flex; justify-content: center; padding: 40px; }
.list { padding: 12px 16px; display: flex; flex-direction: column; gap: 8px; }
.fav-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-card);
  border-radius: 12px;
  border: 1px solid var(--border-color);
  padding: 14px;
}
.fav-info { flex: 1; }
.fav-name { font-size: 15px; font-weight: 600; color: var(--text-primary); display: block; margin-bottom: 4px; }
.fav-meta { display: flex; flex-wrap: wrap; gap: 6px; }
.meta-tag {
  font-size: 11px;
  color: var(--primary);
  background: var(--primary-light);
  border-radius: 4px;
  padding: 2px 6px;
}
.unfav-btn {
  width: 80px;
  height: 100%;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
}
