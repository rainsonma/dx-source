page {
  --primary: #0d9488;
  --primary-light: #f0fdfa;
  --bg-page: #f5f5f5;
  --bg-card: #ffffff;
  --border-color: #f0f0f0;
  --text-primary: #1a1a1a;
  --text-secondary: #888888;
  --destructive: #ef4444;

  --van-primary-color: #0d9488;
  --van-danger-color: #ef4444;
  --van-border-radius-md: 8px;
  --van-border-radius-lg: 12px;
  --van-font-size-md: 14px;
  --van-background: #f5f5f5;
  --van-background-2: #ffffff;
  --van-text-color: #1a1a1a;
  --van-text-color-2: #888888;
  --van-border-color: #f0f0f0;
  --van-icon-font-family: -apple-system, sans-serif;

  --cell-background-color: var(--bg-card);
  --cell-text-color: var(--text-primary);
  --cell-value-color: var(--text-secondary);
  --cell-active-color: rgba(0, 0, 0, 0.04);
  --cell-border-color: var(--border-color);

  background: var(--bg-page);
  font-family: -apple-system, "PingFang SC", sans-serif;
  font-size: 14px;
  color: var(--text-primary);
}

.dark {
  --primary: #14b8a6;
  --primary-light: rgba(20, 184, 166, 0.12);
  --bg-page: #0f0f0f;
  --bg-card: #1c1c1e;
  --border-color: rgba(255, 255, 255, 0.06);
  --text-primary: #f5f5f5;
  --text-secondary: #6b7280;
  --cell-active-color: rgba(255, 255, 255, 0.05);
}
.dark .van-cell::after { border-bottom-color: rgba(255, 255, 255, 0.06); }

.page-container {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 100rpx;
}

.page-container.dark {
  background: #0f0f0f;
}

.card {
  background: var(--bg-card);
  border-radius: 12px;
  border: 1px solid var(--border-color);
  padding: 16px;
  margin: 0 16px 12px;
}
