<van-config-provider theme="{{theme}}">
  <view class="page-container {{theme}}" style="--status-bar-height: {{statusBarHeight}}px">
    <van-loading wx:if="{{loading}}" size="30px" color="{{primaryColor}}" class="center-loader" />
    <block wx:if="{{!loading && profile}}">
      <view class="profile-header" bind:tap="goProfileEdit">
        <view class="avatar-wrap">
          <van-image
            wx:if="{{profile.avatarUrl}}"
            src="{{profile.avatarUrl}}"
            width="64px"
            height="64px"
            radius="50%"
            fit="cover"
          />
          <view wx:else class="avatar-fallback">
            <text>{{avatarChar}}</text>
          </view>
        </view>
        <view class="profile-info">
          <text class="profile-name">{{profile.nickname || profile.username}}</text>
          <view class="profile-badges">
            <text class="level-badge">Lv.{{profile.level}}</text>
            <text class="grade-badge">{{gradeLabelText}}</text>
          </view>
        </view>
      </view>

      <view class="stats-bar">
        <view class="stat-item">
          <text class="stat-v">{{profile.beans}}</text>
          <text class="stat-l">能量豆</text>
        </view>
        <view class="stat-divider" />
        <view class="stat-item">
          <text class="stat-v">{{profile.exp}}</text>
          <text class="stat-l">经验值</text>
        </view>
        <view class="stat-divider" />
        <view class="stat-item stat-item--link" hover-class="stat-item--hover" bind:tap="goRedeem">
          <view class="stat-icon">
            <dx-icon name="ticket" size="22px" color="{{primaryColor}}" />
          </view>
          <text class="stat-l">兑换码</text>
        </view>
      </view>

      <view wx:if="{{profile.vipDueAt}}" class="vip-bar">
        <dx-icon name="crown" size="16px" color="#d97706" />
        <text class="vip-text">会员有效期至 {{vipDueAtText}}</text>
      </view>

      <van-cell-group inset custom-style="margin:16px;">
        <van-cell title="我的团队" is-link center bind:click="goGroups">
          <dx-icon slot="icon" custom-class="cell-icon" name="users" size="20px" color="{{cellIconColor}}" />
        </van-cell>
        <van-cell title="推荐有礼" is-link center bind:click="goInvite">
          <dx-icon slot="icon" custom-class="cell-icon" name="gift" size="20px" color="{{cellIconColor}}" />
        </van-cell>
        <van-cell title="购买会员" is-link center bind:click="goPurchase">
          <dx-icon slot="icon" custom-class="cell-icon" name="crown" size="20px" color="{{cellIconColor}}" />
        </van-cell>
        <van-cell title="收藏的课程" is-link center bind:click="goFavorites">
          <dx-icon slot="icon" custom-class="cell-icon" name="star" size="20px" color="{{cellIconColor}}" />
        </van-cell>
        <van-cell title="深色模式" center bind:click="toggleTheme">
          <dx-icon
            slot="icon"
            custom-class="cell-icon"
            name="{{theme === 'dark' ? 'sun' : 'moon'}}"
            size="20px"
            color="{{cellIconColor}}"
          />
        </van-cell>
      </van-cell-group>

      <view class="logout-btn" hover-class="logout-btn--hover" bind:tap="logout">退出登录</view>
    </block>
  </view>
</van-config-provider>
