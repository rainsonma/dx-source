<van-config-provider theme="{{theme}}">
  <view class="page-container {{theme}}" style="--status-bar-height: {{statusBarHeight}}px">
    <view class="custom-nav">
      <view class="status-bar-spacer"></view>
      <view class="nav-row">
        <view class="back-btn" bind:tap="goBack">
          <dx-icon name="chevron-left" size="22px" color="{{theme === 'dark' ? '#f5f5f5' : '#1a1a1a'}}" />
        </view>
        <text class="nav-title">购买会员</text>
      </view>
    </view>

    <view class="coming-banner">
      <text class="cb-title">即将开放</text>
      <text class="cb-sub">微信支付正在接入中，敬请期待</text>
    </view>

    <view class="tier-list">
      <view wx:for="{{tiers}}" wx:key="id" class="tier-card">
        <view class="tier-info">
          <text class="tier-name">{{item.name}}</text>
          <text class="tier-desc">{{item.desc}}</text>
        </view>
        <view class="tier-right">
          <text class="tier-price">{{item.price}}</text>
          <van-button size="small" bind:click="onBuy" custom-style="opacity:0.6;">购买</van-button>
        </view>
      </view>
    </view>
  </view>
</van-config-provider>
