.page-container {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(56px + env(safe-area-inset-bottom) + 32rpx);
}
.status-bar-spacer {
  height: var(--status-bar-height, 20px);
}
.nav-band {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}
.post-list {
  display: flex;
  flex-direction: column;
  padding-top: 4px;
}
.center-loader {
  display: flex;
  justify-content: center;
  padding: 24px;
}
