.page-container {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(56px + env(safe-area-inset-bottom) + 32rpx);
}
.status-bar-spacer {
  height: var(--status-bar-height, 20px);
}
.nav-band {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}
.post-list {
  display: flex;
  flex-direction: column;
  padding-top: 4px;
}
.center-loader {
  display: flex;
  justify-content: center;
  padding: 24px;
}
.tabs-row {
  background: var(--bg-page);
  --tabs-nav-background-color: transparent;
}
.fab {
  position: fixed;
  right: 24rpx;
  bottom: calc(56px + env(safe-area-inset-bottom) + 32rpx);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 18px rgba(13, 148, 136, 0.32);
  z-index: 10;
}
