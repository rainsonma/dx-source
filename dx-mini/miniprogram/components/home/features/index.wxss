.section-root {
  padding: 40rpx 32rpx 32rpx;
  background: var(--bg-page);
}

.hero-card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
}

.accent-dash {
  width: 48rpx; height: 6rpx; border-radius: 3rpx;
  background: #7c3aed; margin-bottom: 20rpx;
}

.tag {
  display: block; font-size: 22rpx; color: #7c3aed;
  font-weight: 700; letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.headline {
  display: block; font-size: 34rpx; font-weight: 800;
  color: var(--text-primary); line-height: 1.35; margin-bottom: 24rpx;
}

.headline .hl { color: #7c3aed; }

/* ----- Resume chip ----- */

.resume-chip {
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(13, 148, 136, 0.08); border: 1rpx solid #0d9488;
  border-radius: 999rpx; padding: 14rpx 22rpx; margin-bottom: 24rpx;
}

.resume-label {
  font-size: 24rpx; color: #0d9488; font-weight: 600;
  flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* ----- Game item (one-per-mode, stacked inside the hero card) ----- */

.game-item {
  border: 1rpx solid var(--border-color);
  border-radius: 14rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 14rpx;
}

.game-item:last-child {
  margin-bottom: 0;
}

.card-head { display: flex; gap: 16rpx; align-items: flex-start; }

.ico {
  width: 56rpx; height: 56rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.ico-violet { background: #ede9fe; }
.ico-blue   { background: #dbeafe; }
.ico-pink   { background: #fce7f3; }
.ico-red    { background: #fee2e2; }

.card-text { flex: 1; min-width: 0; }

.name {
  display: block; font-size: 28rpx; font-weight: 700;
  color: var(--text-primary); margin-bottom: 4rpx;
}

.desc {
  display: block; font-size: 22rpx; color: var(--text-secondary);
  line-height: 1.5;
}

/* ----- Illustration container ----- */

.illus {
  margin-top: 18rpx; background: rgba(241, 245, 249, 0.6);
  border-radius: 12rpx; overflow: hidden;
}

.page-container.dark .illus { background: rgba(255, 255, 255, 0.04); }

/* --- 连词成句: 4 word pills in a row --- */

.illus-tiles {
  height: 72rpx;
  display: flex; align-items: center; justify-content: center;
  gap: 8rpx; padding: 0 16rpx;
}

.illus-tiles .tile {
  background: var(--bg-card); border: 1rpx solid rgba(148, 163, 184, 0.35);
  border-radius: 8rpx; padding: 6rpx 14rpx;
  font-size: 20rpx; font-weight: 600; color: #5b21b6;
  box-shadow: 0 1rpx 2rpx rgba(15, 23, 42, 0.04);
}

/* --- 词汇配对: 2-column grid with 3 EN ↔ ZH pairs --- */

.illus-match {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rpx 8rpx;
  padding: 8rpx 16rpx;
  align-content: center;
  min-height: 96rpx;
}

.illus-match .tile {
  background: var(--bg-card); border: 1rpx solid rgba(148, 163, 184, 0.35);
  border-radius: 6rpx; padding: 3rpx 8rpx;
  font-size: 18rpx; font-weight: 600;
  box-shadow: 0 1rpx 2rpx rgba(15, 23, 42, 0.04);
  display: flex; align-items: center; justify-content: center;
}

.illus-match .tile.en { color: #0f766e; }
.illus-match .tile.zh { color: #475569; }

/* --- 词汇消消乐: 4×2 grid, 8 shuffled word/translation tiles --- */

.illus-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: 1fr 1fr;
  gap: 4rpx 6rpx;
  padding: 8rpx 12rpx;
  min-height: 96rpx;
  align-content: center;
}

.illus-grid .cell {
  background: var(--bg-card); border: 1rpx solid rgba(148, 163, 184, 0.35);
  border-radius: 6rpx; padding: 3rpx 4rpx;
  font-size: 16rpx; font-weight: 600; color: #334155;
  box-shadow: 0 1rpx 2rpx rgba(15, 23, 42, 0.04);
  overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
  display: flex; align-items: center; justify-content: center;
}

/* --- 词汇对轰: two facing bars with labels and a spark --- */

.illus-battle {
  height: 72rpx;
  display: flex; align-items: center; gap: 10rpx;
  padding: 0 16rpx;
}

.battle-label {
  font-size: 20rpx; font-weight: 700;
  flex-shrink: 0;
}

.battle-label.teal { color: #0d9488; }
.battle-label.red  { color: #e11d48; }

.illus-battle .bar {
  flex: 1; height: 6rpx; border-radius: 3rpx;
}

.illus-battle .bar-teal {
  background: linear-gradient(90deg, #2dd4bf, #0d9488);
  transform-origin: left center;
}

.illus-battle .bar-red {
  background: linear-gradient(90deg, #fb7185, #e11d48);
  transform-origin: right center;
}

.battle-star {
  font-size: 22rpx; color: #f59e0b; flex-shrink: 0;
}
