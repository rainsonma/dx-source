<view class="section-root">
  <view class="hero-card">
    <view class="accent-dash"></view>
    <text class="tag">核心玩法 · 4 种模式，覆盖听说读写</text>
    <text class="headline">挑一个就能上手，<text class="hl">全都玩转就起飞</text></text>

    <view class="resume-chip" wx:if="{{recentSession}}" bind:tap="goResume">
      <text class="resume-label">继续 · {{recentSession.gameName}} Lv.{{recentSession.completedLevels + 1}}</text>
      <dx-icon name="chevron-right" size="14px" color="#0d9488" />
    </view>

    <!-- Card 1: 连词成句 — 4 pills bounce staggered -->
    <view class="game-item">
      <view class="card-head">
        <view class="ico ico-violet"><dx-icon name="keyboard" size="18px" color="#7c3aed" /></view>
        <view class="card-text">
          <text class="name">连词成句</text>
          <text class="desc">看到中文秒拼出英文句子，越快越高分。真实语料替你练习语序和搭配。</text>
        </view>
      </view>
      <view class="illus illus-tiles">
        <text class="tile tile-1">I</text>
        <text class="tile tile-2">love</text>
        <text class="tile tile-3">this</text>
        <text class="tile tile-4">game</text>
      </view>
    </view>

    <!-- Card 2: 词汇配对 — 3 pairs pulse in teal, staggered. Unique
         class per tile so this.animate hits each individually. -->
    <view class="game-item">
      <view class="card-head">
        <view class="ico ico-blue"><dx-icon name="swords" size="18px" color="#0d9488" /></view>
        <view class="card-text">
          <text class="name">词汇配对</text>
          <text class="desc">英文与中文快速配对，限时给分。巩固词汇量和中译英反应速度。</text>
        </view>
      </view>
      <view class="illus illus-match">
        <text class="tile en m1">apple</text>
        <text class="tile zh m2">苹果</text>
        <text class="tile en m3">study</text>
        <text class="tile zh m4">学习</text>
        <text class="tile en m5">smile</text>
        <text class="tile zh m6">微笑</text>
      </view>
    </view>

    <!-- Card 3: 词汇消消乐 — 4 pairs bg+scale pulse, staggered. Unique
         class per cell. Pair map: (e1,e5), (e2,e7), (e3,e6), (e4,e8). -->
    <view class="game-item">
      <view class="card-head">
        <view class="ico ico-pink"><dx-icon name="shuffle" size="18px" color="#059669" /></view>
        <view class="card-text">
          <text class="name">词汇消消乐</text>
          <text class="desc">记忆配对消除，越快消除越高分。玩着玩着就把生词牢牢记住。</text>
        </view>
      </view>
      <view class="illus illus-grid">
        <text class="cell e1">apple</text>
        <text class="cell e2">微笑</text>
        <text class="cell e3">学习</text>
        <text class="cell e4">书</text>
        <text class="cell e5">苹果</text>
        <text class="cell e6">study</text>
        <text class="cell e7">smile</text>
        <text class="cell e8">book</text>
      </view>
    </view>

    <!-- Card 4: 词汇对轰 — teal bar pulses gently, red bar dents harder, star flies right -->
    <view class="game-item">
      <view class="card-head">
        <view class="ico ico-red"><dx-icon name="crosshair" size="18px" color="#dc2626" /></view>
        <view class="card-text">
          <text class="name">词汇对轰</text>
          <text class="desc">和对手拼炮弹。拼对拼快就发射，紧张刺激的词汇对战。</text>
        </view>
      </view>
      <view class="illus illus-battle">
        <text class="battle-label teal">你</text>
        <view class="bar bar-teal"></view>
        <text class="battle-star">✦</text>
        <view class="bar bar-red"></view>
        <text class="battle-label red">对</text>
      </view>
    </view>
  </view>
</view>
